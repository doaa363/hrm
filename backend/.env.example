# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Use a non-default port and a dedicated DB user with least privileges
MONGODB_URI=mongodb://hrm_user:CHANGE_ME@127.0.0.1:27017/EMS_DB?authSource=EMS_DB

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 hex characters (256 bits)
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Store in a secrets manager (AWS Secrets Manager, Vault) in production
GEMINI_API_KEY=REPLACE_WITH_REAL_KEY

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.example.com
